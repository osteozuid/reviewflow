# ReviewFlow SaaS — environment variables
# Copy to .env and fill in values

# ── Branding / Platform Identity ────────────────────────────────────────────
# Change these to rebrand the platform globally (e.g., from ReviewFlow → Domeina)
PLATFORM_NAME=ReviewFlow
TOOL_NAME=ReviewFlow
MARKETING_URL=

# ── Application URLs ───────────────────────────────────────────────────────
# No hardcoded domain names in code — all come from here
APP_NAME=ReviewFlow
APP_BASE_URL=http://localhost:5000

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost/reviewflow

# ── Flask Secret Key ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production

# ── System SMTP — Invite Emails Only ────────────────────────────────────────
# Used for invite emails (from system, not tenant-specific)
# Patient/review emails use SMTP settings from tenant_settings (database)
SYSTEM_SMTP_HOST=smtp.one.com
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=
SYSTEM_SMTP_PASSWORD=
SYSTEM_FROM_EMAIL=
SYSTEM_FROM_NAME=ReviewFlow

# Superadmin setup (used by migrate script)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Test database (used by pytest)
TEST_DATABASE_URL=postgresql://user:password@localhost/reviewflow_test
